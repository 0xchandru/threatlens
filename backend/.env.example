# ============================================================
#  ThreatLens — Environment Configuration Template
#  Copy this file to .env and fill in your values
#  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# 🔑  THREAT INTELLIGENCE API KEYS
# All optional — app works without them (returns "no_api_key")
# ------------------------------------------------------------

# VirusTotal — https://virustotal.com  (free tier: 4 req/min)
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://abuseipdb.com   (free tier: 1,000 req/day)
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com  (free, no hard limit)
ALIENVAULT_API_KEY=

# GreyNoise — https://greynoise.io    (community tier: 1,000 req/day)
GREYNOISE_API_KEY=

# URLhaus — no key needed, always available

# ------------------------------------------------------------
# 🗄️  DATABASE
# Default: SQLite (zero-config, file-based)
# Production: PostgreSQL (Replit managed DB is auto-injected)
# ------------------------------------------------------------

# SQLite (development)
DATABASE_URL=sqlite:///./threatlens.db

# PostgreSQL (production — uncomment and fill)
# DATABASE_URL=postgresql://user:password@localhost:5432/threatlens

# ------------------------------------------------------------
# 🔐  SECURITY
# ------------------------------------------------------------

# JWT signing secret — change this in production!
SECRET_KEY=change-this-to-a-random-secret-in-production

# JWT algorithm (HS256 recommended)
ALGORITHM=HS256

# JWT token expiry in minutes (default: 8 hours)
TOKEN_EXPIRE=480

# ------------------------------------------------------------
# ⚡  PERFORMANCE
# ------------------------------------------------------------

# Redis cache URL (optional — skipped gracefully if unavailable)
REDIS_URL=redis://localhost:6379/0

# API rate limit per analyst per hour
RATE_LIMIT=200

# Async query timeout per source in seconds (default: 10)
# QUERY_TIMEOUT=10

# ------------------------------------------------------------
# 🌐  SECOPS INTEGRATION
# Comma-separated list of allowed CORS origins
# Add your SecOps SIEM URL here to enable cross-origin calls
# ------------------------------------------------------------

# CORS_ORIGINS=http://localhost:3000,https://your-secops-domain.replit.app

# ThreatLens public URL (used by SecOps for absolute API calls)
# THREATLENS_URL=https://your-threatlens.replit.app
